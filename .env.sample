# ── Data ──────────────────────────────────────────────────────────────────────
# Root directory where processed PTB-XL data will be stored after fetch_data.
DATA_DIR=/data/ptbxl

# Directory for cached BERT embeddings and ECG normalisation stats.
CACHE_DIR=/data/cache

# ── Outputs ───────────────────────────────────────────────────────────────────
# Directory where model checkpoints are saved.
CHECKPOINT_DIR=/checkpoints

# Directory where evaluation figures are saved.
FIGURES_DIR=/figures

# ── API Keys ──────────────────────────────────────────────────────────────────
# Anthropic API key — used by fetch_data to translate German reports via Batch API.
ANTHROPIC_API_KEY=sk-ant-...

# Kaggle credentials — used by fetch_data to download PTB-XL.
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_kaggle_api_key

# HuggingFace token — optional, only needed if BioClinicalBERT requires auth.
HF_TOKEN=

# ── SLURM ─────────────────────────────────────────────────────────────────────
# Cluster partition to submit jobs to.
SLURM_PARTITION=gpu

# Cluster account / project code (leave blank if your cluster doesn't use accounts).
SLURM_ACCOUNT=

# Absolute path to the project root on the cluster.
PROJECT_DIR=/home/$USER/gdss_multimodal

# Absolute path to the Python virtual environment.
VENV_DIR=/home/$USER/gdss_multimodal/.venv
